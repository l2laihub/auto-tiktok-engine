# Supabase (shared EternalFrame/DaPortrait project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for script generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Music Generation (optional — leave blank to skip music)
# Option 1 (recommended): Google Lyria 3 via Gemini API — stable, API key auth
# Get key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Option 2 (fallback): Suno AI via gcui-art/suno-api self-hosted server
# Requires running server + browser cookies that expire in ~1 hour
SUNO_API_URL=http://localhost:3100
SUNO_COOKIE=

# TikTok Content Posting API
# Option 1 (recommended): Run `npm run tiktok:setup` for OAuth with auto-refresh
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Must match the redirect URI registered in your TikTok app settings (HTTPS required)
TIKTOK_REDIRECT_URI=https://www.tiktok.com/
# Option 2 (fallback): Static token, no auto-refresh
TIKTOK_ACCESS_TOKEN=

# Output directory for rendered videos
OUTPUT_DIR=./output

# Auto-post scheduler (runs inside the dashboard server)
# Cron expression for when to auto-post scheduled videos (default: Mon/Wed/Fri 10 AM)
SCHEDULE_CRON=0 10 * * 1,3,5
# Set to 'false' to start with scheduler disabled (can toggle from dashboard)
SCHEDULE_ENABLED=true

# Dashboard auth (required for remote access via Cloudflare Tunnel)
# Leave blank for local-only usage (no auth required on localhost)
DASHBOARD_USER=
DASHBOARD_PASS=
