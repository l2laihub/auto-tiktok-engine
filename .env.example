# Supabase (shared EternalFrame/DaPortrait project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for script generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# TikTok Content Posting API (optional — leave blank for manual upload)
TIKTOK_ACCESS_TOKEN=

# Output directory for rendered videos
OUTPUT_DIR=./output
