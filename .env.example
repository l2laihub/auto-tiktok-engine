# Supabase (shared EternalFrame/DaPortrait project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for script generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini API key (optional) — powers BOTH:
#   • Music generation via Lyria 3
#   • Image generation via gemini-3-pro-image-preview (Nano Banana Pro):
#       - self-sourced reveal photos (damaged → restored)
#       - tip video background/b-roll imagery
# Without it, music + image generation are skipped (pipeline still runs).
# Get key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Image model override (optional). Defaults to gemini-3-pro-image-preview
# (Nano Banana Pro — best in-image text rendering, but a preview model that
# costs more / runs slower). Set to gemini-2.5-flash-image for the cheaper,
# faster original Nano Banana.
IMAGE_MODEL=

# Option 2 (fallback): Suno AI via gcui-art/suno-api self-hosted server
# Requires running server + browser cookies that expire in ~1 hour
SUNO_API_URL=http://localhost:3100
SUNO_COOKIE=

# TikTok Content Posting API
# Option 1 (recommended): Run `npm run tiktok:setup` for OAuth with auto-refresh
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Must match the redirect URI registered in your TikTok app settings (HTTPS required)
TIKTOK_REDIRECT_URI=https://www.tiktok.com/
# Option 2 (fallback): Static token, no auto-refresh
TIKTOK_ACCESS_TOKEN=

# Output directory for rendered videos
OUTPUT_DIR=./output

# Auto-post scheduler (runs inside the dashboard server).
# Each content item posts at its own scheduled_for date+time (local timezone);
# a per-minute poll publishes whatever is due. There is no global post time.
# Set to 'false' to start with auto-posting disabled (can toggle from dashboard).
SCHEDULE_ENABLED=true

# Dashboard auth (required for remote access via Cloudflare Tunnel or Coolify)
# Leave blank for local-only usage (no auth required on localhost)
DASHBOARD_USER=
DASHBOARD_PASS=
