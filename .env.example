# Supabase (shared EternalFrame/DaPortrait project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for script generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Suno AI Music Generation (optional — leave blank to skip music)
# Deploy gcui-art/suno-api server, then set these:
SUNO_API_URL=http://localhost:3100
SUNO_COOKIE=

# TikTok Content Posting API
# Option 1 (recommended): Run `npm run tiktok:setup` for OAuth with auto-refresh
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Must match the redirect URI registered in your TikTok app settings (HTTPS required)
TIKTOK_REDIRECT_URI=https://www.tiktok.com/
# Option 2 (fallback): Static token, no auto-refresh
TIKTOK_ACCESS_TOKEN=

# Output directory for rendered videos
OUTPUT_DIR=./output

# Dashboard auth (required) — used for HTTP Basic Auth on the Express dashboard
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-to-something-long-and-random
