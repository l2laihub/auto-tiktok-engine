    <mxCell id="e_merge_to_posted" value="success" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#3D9CA8;strokeWidth=2;fontColor=#3D9CA8;fontSize=10;" edge="1" parent="1" source="merge_post" target="status_posted">
