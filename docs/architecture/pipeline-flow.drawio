    <!-- Status: rendering → rendered -->
    <mxCell id="status_rendered" value="rendering → rendered" style="text;html=1;strokeColor=#3D9CA8;fillColor=#1A1A2E;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontColor=#FFB74D;fontSize=10;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="490" y="1116" width="160" height="26" as="geometry" />
