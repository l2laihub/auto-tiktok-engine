    <mxCell id="step5_detail" value="Upload to Supabase Storage bucket 'videos'&#xa;path: tiktok-videos/{filename}&#xa;→ get public URL → update video_url" style="text;html=1;strokeColor=#E85A71;fillColor=#1A1A2E;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontColor=#FAFAFA;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="240" y="1104" width="220" height="52" as="geometry" />
    </mxCell>
    <mxCell id="e_step5_to_detail" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E85A71;strokeWidth=1;" edge="1" parent="1" source="step5" target="step5_detail">
      <mxGeometry relative="1" as="geometry" />
