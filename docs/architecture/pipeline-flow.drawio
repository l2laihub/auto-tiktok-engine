    <!-- ─────── STEP 6 ─────── -->
    <mxCell id="step6" value="Step 6: Post to TikTok&#xa;postToTikTok()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E85A71;strokeColor=#E85A71;fontColor=#FAFAFA;fontSize=13;fontStyle=1;" vertex="1" parent="1">
