    <!-- --post-only jumps here -->
    <mxCell id="e_postonly_to_step6" value="Yes&#xa;(jump to Step 6)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#FFB74D;strokeWidth=2;dashed=1;fontColor=#FFB74D;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="dec_postonly" target="step6">
