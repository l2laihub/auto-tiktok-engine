    <mxCell id="status_failed" value="rendered → failed&#xa;(post_error saved to DB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF4444;strokeColor=#FF4444;fontColor=#FAFAFA;fontSize=11;fontStyle=1;" vertex="1" parent="1">
