    <!-- PAIR 3: 17.5s-25s -->
    <!-- Before P3 -->
    <mxCell id="tl-p3-before" value="&lt;b&gt;Before&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px&apos;&gt;zoom · 3s&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E85A71;strokeColor=#A03050;strokeWidth=1;fontColor=#FAFAFA;fontSize=11;" vertex="1" parent="1">
