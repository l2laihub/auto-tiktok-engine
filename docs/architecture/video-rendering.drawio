    <!-- Total duration label -->
    <mxCell id="tl-total" value="30s total" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#FFB74D;" vertex="1" parent="1">
      <mxGeometry x="1197" y="726" width="183" height="60" as="geometry" />
    </mxCell>

    <!-- Timeline time labels -->
    <mxCell id="tl-label-10s" value="10s" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#9090AA;" vertex="1" parent="1">
      <mxGeometry x="447" y="790" width="30" height="16" as="geometry" />
    </mxCell>
    <mxCell id="tl-label-17s" value="17.5s" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#9090AA;" vertex="1" parent="1">
      <mxGeometry x="738" y="790" width="36" height="16" as="geometry" />
