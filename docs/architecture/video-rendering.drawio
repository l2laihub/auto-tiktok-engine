    </mxCell>
    <mxCell id="leg-wipe" value="Wipe" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEEEE;strokeColor=#AAAAAA;fontColor=#1A1A2E;fontSize=9;" vertex="1" parent="1">
