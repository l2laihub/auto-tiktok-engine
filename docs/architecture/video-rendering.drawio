    <mxCell id="leg-cta" value="CTA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E85A71;strokeColor=#A03050;fontColor=#FAFAFA;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="364" y="826" width="60" height="20" as="geometry" />
