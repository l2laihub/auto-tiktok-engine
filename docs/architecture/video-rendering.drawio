    <!-- Frame ruler label -->
    <mxCell id="tl-label-0s" value="0s" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#9090AA;" vertex="1" parent="1">
      <mxGeometry x="26" y="790" width="30" height="16" as="geometry" />
