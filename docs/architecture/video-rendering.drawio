    <mxCell id="leg-overlap-note" value="Shaded edges indicate 0.5s overlap between before/wipe and wipe/after phases" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#9090AA;" vertex="1" parent="1">
      <mxGeometry x="510" y="826" width="420" height="20" as="geometry" />
