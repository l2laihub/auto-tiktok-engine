    <!-- Scale: total ~26s for 3 pairs: 3+0.5+(3+1.5+3)*3+0.5*2+3.5 = 3+0.5+22.5+1+3.5=30.5s
         Simplify to fit 1354px. Use 1 second = ~44px approx.
         Hook 3s, Pair1(before 3s, trans 1.5s, after 3s), gap 0.5s, Pair2(same), gap 0.5s, Pair3(same), CTA 3.5s
         Total = 3 + (3+1.5+3)*3 + 0.5*2 + 3.5 = 3 + 22.5 + 1 + 3.5 = 30s
         1354px / 30s ≈ 45px/s
    -->

    <!-- Hook: 0-3s = 0..135px offset 26 -->
    <mxCell id="tl-hook" value="&lt;b&gt;Hook&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px&apos;&gt;3s&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFB74D;strokeColor=#CC8800;strokeWidth=1;fontColor=#1A1A2E;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="26" y="726" width="135" height="60" as="geometry" />
    </mxCell>
    <mxCell id="tl-label-3s" value="3s" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#9090AA;" vertex="1" parent="1">
      <mxGeometry x="154" y="790" width="30" height="16" as="geometry" />
    </mxCell>

    <!-- PAIR 1 -->
    <!-- Before: 3s-6s = 135..270px offset 26 = 161..296 -->
    <mxCell id="tl-p1-before" value="&lt;b&gt;Before&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px&apos;&gt;zoom · 3s&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E85A71;strokeColor=#A03050;strokeWidth=1;fontColor=#FAFAFA;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="161" y="726" width="120" height="60" as="geometry" />
    </mxCell>

    <!-- Transition: 5.5s-7s overlap with before end and after start
         5.5s=247.5+26=273, 7s=315+26=341 => x=273, width=68 -->
    <mxCell id="tl-p1-trans" value="&lt;b&gt;Wipe&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px&apos;&gt;1.5s&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEEEE;strokeColor=#AAAAAA;strokeWidth=1;fontColor=#1A1A2E;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="263" y="726" width="67" height="60" as="geometry" />
    </mxCell>

    <!-- After: 6.5s-9.5s => 6.5*45+26=319, width=3*45=135 -->
    <mxCell id="tl-p1-after" value="&lt;b&gt;After&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px&apos;&gt;pan · 3s&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3D9CA8;strokeColor=#2A7080;strokeWidth=1;fontColor=#FAFAFA;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="316" y="726" width="120" height="60" as="geometry" />
    </mxCell>

    <!-- Overlap annotation P1 before/trans -->
