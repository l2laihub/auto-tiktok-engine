    <!-- Timeline background -->
    <mxCell id="tl-track" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#252535;strokeColor=#444466;strokeWidth=1;" vertex="1" parent="1">
      <mxGeometry x="26" y="726" width="1354" height="60" as="geometry" />
