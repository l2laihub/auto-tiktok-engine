      <mxGeometry x="910" y="726" width="120" height="60" as="geometry" />
    </mxCell>

    <!-- CTA: 26.5s-30s = 3.5s => 26.5*45+26=1218, width=157 -->
    <mxCell id="tl-cta" value="&lt;b&gt;CTA&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px&apos;&gt;3.5s&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E85A71;strokeColor=#A03050;strokeWidth=1;fontColor=#FAFAFA;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="1030" y="726" width="157" height="60" as="geometry" />
