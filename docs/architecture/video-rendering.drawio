      <mxGeometry x="312" y="732" width="60" height="14" as="geometry" />
    </mxCell>

    <!-- Gap after P1: 9.5s-10s = 0.5s => 427.5+26=453, width=22 -->
    <mxCell id="tl-gap1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A1A2E;strokeColor=#444466;strokeWidth=1;" vertex="1" parent="1">
